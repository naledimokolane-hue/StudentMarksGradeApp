<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="283dp"
        android:layout_height="32dp"
        android:layout_marginStart="64dp"
        android:layout_marginTop="25dp"
        android:text="Student Marks Grade App"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txtStudentNo"
        android:layout_width="370dp"
        android:layout_height="40dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="33dp"
        android:ems="10"
        android:hint="Student No."
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <EditText
        android:id="@+id/txtName"
        android:layout_width="372dp"
        android:layout_height="49dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="16dp"
        android:ems="10"
        android:hint="Name"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtStudentNo" />

    <EditText
        android:id="@+id/txtAge"
        android:layout_width="371dp"
        android:layout_height="46dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="13dp"
        android:ems="10"
        android:hint="Age"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtName" />

    <EditText
        android:id="@+id/txtSubject"
        android:layout_width="369dp"
        android:layout_height="46dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="9dp"
        android:ems="10"
        android:hint="Subject"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtAge" />

    <EditText
        android:id="@+id/txtMark"
        android:layout_width="372dp"
        android:layout_height="49dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="13dp"
        android:ems="10"
        android:hint="Mark Obtained (0-100)"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtSubject" />

    <Button
        android:id="@+id/btnEvaluate"
        android:layout_width="339dp"
        android:layout_height="49dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Compute Grade"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtMark" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="340dp"
        android:layout_height="48dp"
        android:layout_marginStart="21dp"
        android:layout_marginTop="12dp"
        android:text="Clear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnEvaluate" />

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="346dp"
        android:layout_height="165dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="23dp"
        android:text="Results will appear hear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnClear" />
</androidx.constraintlayout.widget.ConstraintLayout>